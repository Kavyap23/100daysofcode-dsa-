#include <stdio.h>

#define MAX 10000

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int prefix_sum = 0;
    int count = 0;

    // Using simple frequency array (shifted index)
    int freq[2 * MAX + 1] = {0};
    int offset = MAX;

    freq[offset] = 1; // for prefix sum = 0

    for(int i = 0; i < n; i++) {
        prefix_sum += arr[i];

        if (freq[prefix_sum + offset] > 0) {
            count += freq[prefix_sum + offset];
        }

        freq[prefix_sum + offset]++;
    }

    printf("%d", count);

    return 0;
}
