#include <stdio.h>

#define MAX 100

int queue[MAX];
int front = 0, rear = -1;
int size = 0;

// Enqueue
void enqueue(int value, int capacity) {
    if (size == capacity) return; // full

    rear = (rear + 1) % capacity;
    queue[rear] = value;
    size++;
}

// Dequeue
void dequeue(int capacity) {
    if (size == 0) return; // empty

    front = (front + 1) % capacity;
    size--;
}

// Display
void display(int capacity) {
    int i = front;

    for (int count = 0; count < size; count++) {
        printf("%d ", queue[i]);
        i = (i + 1) % capacity;
    }
}

int main() {
    int n, m;
    scanf("%d", &n);

    int arr[n];

    // Input elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        enqueue(arr[i], n);
    }

    scanf("%d", &m);

    // Perform m dequeues
    for (int i = 0; i < m; i++) {
        dequeue(n);
    }

    display(n);

    return 0;
}
